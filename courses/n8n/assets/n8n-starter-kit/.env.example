# n8n-starter-kit 環境變數範本
# 用法：複製為 .env 並填入自己的值（首次啟動時 start 腳本會自動幫你做）
# Compose 啟動時會自動讀取 .env，再注入到容器

# ---- 時區（影響 Schedule Trigger / Cron 觸發時間） ----
GENERIC_TIMEZONE=Asia/Taipei

# ---- PostgreSQL（n8n 資料庫） ----
# ⚠️ 重要：密碼一旦設定（第一次啟動之後）就不要再改。
# postgres 第一次啟動會把密碼寫進資料庫；之後改 .env 不會自動更新 postgres 內部密碼，
# 會導致 n8n 連 postgres 報「password authentication failed」。
# 真要改密碼，必須先 docker compose -f n8n-compose.yml down -v 清掉 volume（會清資料）。
POSTGRES_USER=n8n
POSTGRES_PASSWORD=please_change_me_to_a_strong_password
POSTGRES_DB=n8n

# ---- Webhook 對外 URL ----
# 預設用 localhost；接 Cloudflare Tunnel 後改填外部網址，例如：
# WEBHOOK_URL=https://n8n.your-domain.example.com/
# N8N_HOST=n8n.your-domain.example.com
# N8N_PROTOCOL=https
# N8N_SECURE_COOKIE=true
WEBHOOK_URL=http://localhost:5678/
N8N_HOST=localhost
N8N_PROTOCOL=http

# ---- Secure Cookie ----
# localhost HTTP 訪問必設 false（n8n 預設要求 HTTPS，不設 false 會擋登入頁）
# 接 Cloudflare Tunnel HTTPS 後改成 true 提升安全
N8N_SECURE_COOKIE=false

# ---- BASIC_AUTH（接 Cloudflare Tunnel 對外時必設）----
# n8n editor 對外暴露時，先在這層擋一道 Basic Auth；
# 配合 Owner Account（n8n 內建）形成兩層防線。
# 純 localhost 使用時保持註解狀態即可（Owner Account 已足夠）。
# 詳見 README「安全設定」章節。
# N8N_BASIC_AUTH_ACTIVE=true
# N8N_BASIC_AUTH_USER=your_username
# N8N_BASIC_AUTH_PASSWORD=replace_with_strong_password
